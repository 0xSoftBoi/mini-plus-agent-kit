# Anthropic API key for the autonomous agent
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model used by the agent
MPAK_MODEL=claude-opus-4-8

# Telegram chat surface (mpak telegram) — the openClaw flagship demo
TELEGRAM_BOT_TOKEN=

# --- Backend A: FrodoBots Earth Rover Mini+ (Earth Rovers SDK) ---
# Run `hypercorn main:app` in the earth-rovers-sdk repo.
ROVER_URL=http://localhost:8000

# --- Backend B: Waveshare UGV via the onchain-rover robot-harness ---
# robot-harness (Rust) on the Jetson, or the sidecar adapter that proxies it.
HARNESS_URL=http://localhost:8000
# Node sidecar — proof tracker + onchain settle flow (POST /proof).
SIDECAR_URL=http://localhost:4021
# Walrus endpoints for proof storage (match the sidecar/robot defaults).
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# --- Verifiable Robotic Work: BitRobot subnet API (docs.bitrobot.ai) ---
BITROBOT_API_URL=https://api.bitrobot.ai
BITROBOT_SUBNET_ID=
BITROBOT_API_KEY=brb_...
BITROBOT_OWNER=            # Solana wallet that owns the robot Entity NFT
BITROBOT_RESOURCE_NAME=    # e.g. ugv_001 (the registered resource VRW attributes to)
